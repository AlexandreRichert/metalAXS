# ----------------------------------------------------------------------
# Configuration Sanity — copiez ce fichier en `.env.local` et renseignez
# vos valeurs. `.env.local` n'est jamais versionné.
# ----------------------------------------------------------------------

# Identifiant du projet Sanity (8 caractères) — visible dans manage.sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Nom du dataset (généralement "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Version d'API Sanity (date). Laissez la valeur par défaut sauf besoin précis.
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01

# Jeton d'ÉCRITURE (permission « Editor ») — REQUIS pour enregistrer les
# réponses au questionnaire. À créer dans manage.sanity.io → API → Tokens.
# NE JAMAIS préfixer par NEXT_PUBLIC_ (resterait secret côté serveur).
SANITY_API_WRITE_TOKEN=

# Jeton de LECTURE (permission « Viewer ») — optionnel, pour prévisualiser
# les brouillons (Draft Mode / Presentation).
SANITY_API_READ_TOKEN=
